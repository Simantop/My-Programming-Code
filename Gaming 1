#include <stdio.h>
#include <stdlib.h>
#include <time.h>

int main() {
    int secret, guess, tries = 0;
    
    // Seed the random number generator
    srand(time(0)); 
    secret = rand() % 100 + 1; // Number between 1 and 100

    printf("--- Guess My Number Game ---\n");

    do {
        printf("Enter your guess: ");
        scanf("%d", &guess);
        tries++;

        if (guess > secret) {
            printf("Too high! Try again.\n");
        } else if (guess < secret) {
            printf("Too low! Try again.\n");
        } else {
            printf("\nCongratulations! You got it in %d tries.\n", tries);
        }
    } while (guess != secret);

    return 0;
}

